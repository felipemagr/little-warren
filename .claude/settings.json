{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(make *)",
      "Bash(uv *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(ruff *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Read",
      "Edit",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys,subprocess;d=json.load(sys.stdin);f=d.get('tool_input',{}).get('file_path','');f.endswith('.py') and subprocess.run(['uv','run','ruff','format','--quiet',f],capture_output=True)\""
          }
        ]
      }
    ]
  }
}
